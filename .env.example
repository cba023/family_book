# ========== Supabase（本地 Docker）==========
# 1) 安装 Docker 后，在项目根目录执行：npx supabase start
# 2) 终端会输出 API URL 与 anon（publishable）key，填到下面两行
# 3) 首次应用数据库结构：npx supabase db reset   （会执行 supabase/migrations 下的 SQL）
#
# 本机浏览器访问 Next（npm run dev）时通常使用：
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#
# 若 Next 跑在 Docker 里、Supabase 跑在宿主机 CLI，则使用：
# NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 服务端专用（勿提交到公开仓库）。超级管理员「用户管理」页需列出 Auth 用户时使用。
# SUPABASE_SERVICE_ROLE_KEY=

# 可选：登录页预填（仅本地调试；账户名规则见 lib/auth/account-username.ts）
# NEXT_PUBLIC_LOGIN_USERNAME=
# NEXT_PUBLIC_LOGIN_PASSWORD=

# ========== 角色 ==========
# 首个注册用户自动为 super_admin；其余为 user。super_admin 在站内「用户管理」可将他人设为 admin。
# admin 与 super_admin 均可维护族谱数据。若需 SQL 手工改角色：profiles.role ∈ super_admin | admin | user

# 家族姓氏
NEXT_PUBLIC_FAMILY_SURNAME="陈"
