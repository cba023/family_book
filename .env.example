# ========== PostgreSQL ==========
# 推荐：docker compose up postgres（见项目根目录 docker-compose.yml）
# 本机连接示例：
DATABASE_URL=postgresql://genealogy:genealogy@127.0.0.1:5432/genealogy
#
# 与数据库容器同栈运行 Next 应用时（compose 内 service 名 postgres）：
# DATABASE_URL=postgresql://genealogy:genealogy@postgres:5432/genealogy

# ========== 会话签名（必填，至少 16 字符）==========
AUTH_SECRET=请替换为随机长字符串

# 可选：登录页预填（仅本地调试）
# NEXT_PUBLIC_LOGIN_USERNAME=
# NEXT_PUBLIC_LOGIN_PASSWORD=

# ========== 角色 ==========
# 首个注册用户自动为 super_admin；其余为 user。super_admin 在「用户管理」可将他人设为 admin。

# 家族姓氏
NEXT_PUBLIC_FAMILY_SURNAME="陈"
